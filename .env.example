# powerbi-mcp-proxy — environment variables
#
# Copy to .env for local development. In production, prefer Key Vault refs
# (the included Terraform wires PBI_CLIENT_SECRET and JWT_SIGNING_KEY to
# Key Vault automatically — do NOT paste secrets into App Settings directly).

# Entra ID app registration (single-tenant)
PBI_CLIENT_ID=00000000-0000-0000-0000-000000000000
PBI_CLIENT_SECRET=<your-app-client-secret>

# Your Entra tenant GUID. Must NOT be 'common', 'organizations', or 'consumers' —
# multi-tenant disables issuer validation and lets any Microsoft account sign in.
PBI_TENANT_ID=00000000-0000-0000-0000-000000000000

# Public URL of this server (used as OAuth base_url and redirect base).
# Must be https:// for any non-localhost host.
MCP_SERVER_URL=http://localhost:8000

# Comma-separated allowlist of OAuth client redirect URIs (path wildcards OK).
# Defaults to Claude.ai if unset. NEVER set to a bare '*'.
# Example for multiple clients:
#   MCP_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/*,https://chatgpt.com/connector_platform_oauth_redirect
MCP_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/*

# JWT signing key for FastMCP auth state (256-bit recommended).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SIGNING_KEY=<random-256-bit-key>
